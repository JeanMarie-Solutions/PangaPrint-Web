# PrintFix Assistant Environment Configuration
# Copy this file to .env and update values for your deployment

# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-app-name.herokuapp.com,your-app.railway.app,your-app.onrender.com

# Database (leave empty for SQLite, or set DATABASE_URL for PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:port/database

# File Storage Paths (optional - defaults will be used if not set)
# WATCH_FOLDER=/app/watch
# TEMP_FOLDER=/app/temp
# OUTPUT_FOLDER=/app/output
# LOGS_FOLDER=/app/logs

# Print Settings (optional)
# DEFAULT_PRINTER=Microsoft Print to PDF

# Hotkey Settings (optional)
# HOTKEY=ctrl+shift+p

# File Upload Limits
MAX_FILE_SIZE_MB=500
ALLOWED_FILE_FORMATS=pdf

# Processing Settings
DEFAULT_PAGE_REVERSAL=False
OPEN_AFTER_PROCESSING=False

# System Settings
AUTO_PRINT_ENABLED=False
WATCH_FOLDER_ENABLED=True